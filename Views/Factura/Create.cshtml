@{
    ViewData["Title"] = "Nueva Factura";
}

<form method="post" action="/Factura/Create">
    <div class="row">
        <!-- Emisor -->
        <div class="col-md-6">
            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-building mr-2"></i>Emisor</h3>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <label>Nombre / Razón Social</label>
                        <input name="EmisorNombre" class="form-control" required placeholder="Junior Mora S.A." />
                    </div>
                    <div class="form-group">
                        <label>Cédula Jurídica</label>
                        <input name="EmisorCedula" class="form-control" required placeholder="3-101-123456" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Receptor -->
        <div class="col-md-6">
            <div class="card card-info">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-user mr-2"></i>Receptor</h3>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <label>Nombre</label>
                        <input name="ReceptorNombre" class="form-control" required placeholder="Cliente S.A." />
                    </div>
                    <div class="form-group">
                        <label>Cédula</label>
                        <input name="ReceptorCedula" class="form-control" required placeholder="1-1234-5678" />
                    </div>
                    <div class="form-group">
                        <label>Correo Electrónico</label>
                        <input name="ReceptorCorreo" type="email" class="form-control" placeholder="cliente@correo.com" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Líneas de Detalle -->
    <div class="card card-success">
        <div class="card-header">
            <h3 class="card-title"><i class="fas fa-list-ul mr-2"></i>Líneas de Detalle</h3>
            <div class="card-tools">
                <button type="button" class="btn btn-sm btn-light" id="btnAgregarLinea">
                    <i class="fas fa-plus"></i> Agregar línea
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            <table class="table mb-0" id="tablaLineas">
                <thead class="thead-light">
                    <tr>
                        <th>Descripción</th>
                        <th style="width:110px">Cantidad</th>
                        <th style="width:140px">Precio Unit. (₡)</th>
                        <th style="width:100px">IVA %</th>
                        <th style="width:140px">Total</th>
                        <th style="width:50px"></th>
                    </tr>
                </thead>
                <tbody id="lineasBody"></tbody>
            </table>
        </div>
        <div class="card-footer">
            <div class="row">
                <div class="col text-right">
                    <span class="text-muted mr-3">Subtotal: ₡<span id="subtotalGeneral">0.00</span></span>
                    <span class="text-muted mr-3">IVA: ₡<span id="ivaGeneral">0.00</span></span>
                    <strong class="text-lg">Total: ₡<span id="totalGeneral">0.00</span></strong>
                </div>
            </div>
        </div>
    </div>

    <div class="text-right mb-4">
        <a href="/Factura" class="btn btn-secondary mr-2">
            <i class="fas fa-arrow-left"></i> Cancelar
        </a>
        <button type="submit" class="btn btn-success btn-lg">
            <i class="fas fa-save"></i> Guardar Factura
        </button>
    </div>
</form>

@section Scripts {
    <script>
        let lineaCount = 0;

        function agregarLinea() {
            lineaCount++;
            const tbody = document.getElementById('lineasBody');
            const tr = document.createElement('tr');
            tr.id = 'linea_' + lineaCount;
            tr.innerHTML = `
                <td><input name="descripciones" class="form-control form-control-sm" required placeholder="Descripción del servicio o producto"/></td>
                <td><input name="cantidades" type="number" step="0.01" min="0.01" value="1" class="form-control form-control-sm calc" required /></td>
                <td><input name="precios" type="number" step="0.01" min="0" value="0" class="form-control form-control-sm calc" required /></td>
                <td>
                    <select name="ivaPorcentajes" class="form-control form-control-sm calc">
                        <option value="13">13%</option>
                        <option value="4">4%</option>
                        <option value="2">2%</option>
                        <option value="1">1%</option>
                        <option value="0">0%</option>
                    </select>
                </td>
                <td><strong class="linea-total text-success">₡0.00</strong></td>
                <td>
                    <button type="button" class="btn btn-sm btn-danger" onclick="eliminarLinea(${lineaCount})">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            `;
            tbody.appendChild(tr);
            tr.querySelectorAll('.calc').forEach(i => i.addEventListener('change', calcularTotales));
            tr.querySelectorAll('.calc').forEach(i => i.addEventListener('input', calcularTotales));
        }

        function eliminarLinea(id) {
            document.getElementById('linea_' + id)?.remove();
            calcularTotales();
        }

        function calcularTotales() {
            let subtotal = 0, totalIva = 0;

            document.querySelectorAll('#lineasBody tr').forEach(tr => {
                const cant = parseFloat(tr.querySelector('[name="cantidades"]')?.value) || 0;
                const precio = parseFloat(tr.querySelector('[name="precios"]')?.value) || 0;
                const iva = parseFloat(tr.querySelector('[name="ivaPorcentajes"]')?.value) || 0;

                const sub = cant * precio;
                const montoIva = sub * (iva / 100);
                const total = sub + montoIva;

                subtotal += sub;
                totalIva += montoIva;
                tr.querySelector('.linea-total').textContent = '₡' + total.toFixed(2);
            });

            document.getElementById('subtotalGeneral').textContent = subtotal.toFixed(2);
            document.getElementById('ivaGeneral').textContent = totalIva.toFixed(2);
            document.getElementById('totalGeneral').textContent = (subtotal + totalIva).toFixed(2);
        }

        document.getElementById('btnAgregarLinea').addEventListener('click', agregarLinea);
        agregarLinea(); // Primera línea automática
    </script>
}
