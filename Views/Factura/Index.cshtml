@model List<DemoFacturacionHacienda.Models.Entities.Factura>
@{
    ViewData["Title"] = "Facturas Emitidas";
}

<div class="row mb-3">
    <div class="col">
        <a href="/Factura/Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nueva Factura
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-list mr-2"></i>Comprobantes Electrónicos
        </h3>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="thead-dark">
                <tr>
                    <th>Consecutivo</th>
                    <th>Fecha</th>
                    <th>Receptor</th>
                    <th>Total</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model)
                {
                    <tr>
                        <td><code>@f.NumeroConsecutivo</code></td>
                        <td>@f.FechaEmision.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@f.ReceptorNombre</td>
                        <td>₡@f.TotalComprobante.ToString("N2")</td>
                        <td>
                            @{
                                var badge = f.Estado switch
                                {
                                    DemoFacturacionHacienda.Models.Entities.EstadoFactura.Aceptada => "success",
                                    DemoFacturacionHacienda.Models.Entities.EstadoFactura.Rechazada => "danger",
                                    DemoFacturacionHacienda.Models.Entities.EstadoFactura.Enviada => "info",
                                    DemoFacturacionHacienda.Models.Entities.EstadoFactura.Error => "warning",
                                    _ => "secondary"
                                };
                            }
                            <span class="badge badge-@badge">@f.Estado</span>
                        </td>
                        <td>
                            <a href="/Factura/Details/@f.Id" class="btn btn-sm btn-info">
                                <i class="fas fa-eye"></i> Detalle
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-5">
                            <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                            No hay facturas registradas aún.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>